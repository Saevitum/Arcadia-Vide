{
  "name": "Arcadia-React",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "$className": "ReplicatedStorage",
      "$ignoreUnknownInstances": true,

      "Shared": {
        "$path": "src/shared"
      },
      "Packages": { 
        "$path": "Packages"
      }
    },

    "ServerScriptService": {
      "$className": "ServerScriptService",
      "$ignoreUnknownInstances": true,
      "Server": {
        "$path": "src/server"
      }
    },

    "ServerStorage": {
      "$className": "ServerStorage",
      "$ignoreUnknownInstances": true,
      "Vault": {
        "$path": "src/Vault",
        "$className": "Folder"
      }
    },

    "StarterPlayer": {
      "$className": "StarterPlayer",
      "$ignoreUnknownInstances": true,
      "StarterPlayerScripts": {
        "$className": "StarterPlayerScripts",
        "$ignoreUnknownInstances": true,
        "Client": {
          "$path": "src/client"
        }
      }
    }

 
  }
}